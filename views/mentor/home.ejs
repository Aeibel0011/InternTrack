<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Mentor Dashboard - InternTrack</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- Main CSS -->
  <link rel="stylesheet" href="/stylesheets/style.css">
<link rel="stylesheet" href="/stylesheets/mentor.css">
  
</head>
<body>

<!-- ================= NAVBAR ================= -->
<%- include('../partials/mentor-navbar.ejs') %>

<main class="content-main">

  <!-- WELCOME SECTION -->
  <section class="welcome-section">
    <div class="welcome-content">
      <h1> Welcome back, <%= mentor?.fullName || "Mentor" %>!</h1>
      <p><strong><%= mentor?.companyName || "Your Company" %></strong> | Guide your interns toward success. Monitor progress, provide feedback, and help them grow.</p>

      <div class="stats-cards">
        <div class="stat-card">
          <div class="stat-label">Total Students</div>
          <div class="stat-number"><%= assignedStudents?.length || 0 %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Active Internships</div>
          <div class="stat-number"><%= assignedStudents?.length || 0 %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Pending Reviews</div>
          <div class="stat-number">0</div>
        </div>
      </div>
    </div>
  </section>

  <!-- MY STUDENTS SECTION -->
  <section>
    <h2 class="section-title">My Students</h2>

    <div class="students-grid">
      <% if (assignedStudents && assignedStudents.length > 0) { %>
        <% assignedStudents.forEach((student, index) => { %>
          <!-- Student Card -->
          <div class="student-card">
            <div class="student-header">
              <div class="student-info">
                <h3><%= student.firstName %> <%= student.lastName %></h3>
                <div class="student-id">Email: <%= student.studentEmail %></div>
              </div>
              <span class="status-badge status-active">Active</span>
            </div>

            <p class="internship-title"> <%= student.companyName %></p>

            <div class="progress-section">
              <div class="progress-label">
                <span>Progress</span>
                <span style="color: #4CAF50; font-weight: 700;">75%</span>
              </div>
              <div class="progress-bar">
                <div class="progress-fill"></div>
              </div>
            </div>

            <div class="student-actions">
              <div>
                <button class="btn btn-primary btn-with-help">View Details</button>
                <!-- <span class="helper-text">Check student info & progress</span> -->
              </div>
              <div>
                <button class="btn btn-secondary btn-with-help">Assign Task</button>
                <!-- <span class="helper-text">Create new task</span> -->
              </div>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <!-- Empty State Message -->
        <div class="empty-state">
          <h3>📋 No students assigned yet</h3>
          <p>Students will appear here once they join your mentorship</p>
        </div>
      <% } %>
    </div>
  </section>

