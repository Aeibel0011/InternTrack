<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>InternTrack | Internship Management System</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <style>
    :root {
      --green-dark: #1B5E20;
      --green-mid: #2E7D32;
      --green-light: #A5D6A7;
      --white: #FFFFFF;
      --section-gray: #f4f7f4;
      --text-dark: #123018;
      --shadow-soft: 0 18px 40px rgba(27, 94, 32, 0.14);
      --shadow-card: 0 12px 30px rgba(27, 94, 32, 0.1);
      --radius-lg: 22px;
      --radius-md: 16px;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      overflow-x: hidden;
    }

    body {
      font-family: "Poppins", sans-serif;
      color: var(--text-dark);
      background: linear-gradient(180deg, #f7fbf7 0%, #ffffff 36%, #f5f8f5 100%);
    }

    .section-space {
      padding: 92px 0;
    }

    .section-title {
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 700;
      margin-bottom: 14px;
      color: #104116;
    }

    .section-subtitle {
      color: #49624d;
      max-width: 700px;
      margin: 0 auto;
    }

    .site-navbar {
      transition: background-color 0.35s ease, box-shadow 0.35s ease, padding 0.35s ease;
      padding: 1rem 0;
      background: transparent;
    }

    .site-navbar.scrolled {
      background: rgba(255, 255, 255, 0.93);
      box-shadow: 0 8px 22px rgba(11, 33, 14, 0.12);
      backdrop-filter: blur(10px);
      padding: 0.72rem 0;
    }

    .brand-logo {
      font-weight: 800;
      font-size: 1.55rem;
      color: var(--green-dark);
      letter-spacing: 0.2px;
    }

    .navbar-nav .nav-link {
      color: #1f4f26;
      font-weight: 500;
      position: relative;
      margin: 0 0.22rem;
    }

    .navbar-nav .nav-link::after {
      content: "";
      position: absolute;
      left: 0.55rem;
      bottom: 0.3rem;
      width: 0;
      height: 2px;
      background: var(--green-mid);
      transition: width 0.25s ease;
    }

    .navbar-nav .nav-link:hover::after {
      width: calc(100% - 1.1rem);
    }

    .btn-main {
      border-radius: 999px;
      padding: 0.64rem 1.2rem;
      font-weight: 600;
      transition: all 0.28s ease;
    }

    .btn-login {
      background: var(--green-dark);
      border: 1px solid var(--green-dark);
      color: var(--white);
      box-shadow: 0 12px 28px rgba(27, 94, 32, 0.2);
    }

    .btn-login:hover {
      background: #174f1b;
      border-color: #174f1b;
      color: var(--white);
      box-shadow: 0 16px 34px rgba(27, 94, 32, 0.3);
      transform: translateY(-2px);
    }

    .btn-outline-main {
      color: var(--green-dark);
      border: 1.5px solid var(--green-mid);
      background: rgba(255, 255, 255, 0.5);
    }

    .btn-outline-main:hover {
      background: var(--green-dark);
      border-color: var(--green-dark);
      color: var(--white);
      box-shadow: 0 16px 34px rgba(27, 94, 32, 0.25);
      transform: translateY(-2px);
    }

    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      position: relative;
      padding-top: 90px;
      background:
        radial-gradient(circle at 84% 22%, rgba(165, 214, 167, 0.45), transparent 38%),
        radial-gradient(circle at 15% 78%, rgba(46, 125, 50, 0.12), transparent 44%);
    }

    .hero h1 {
      font-weight: 800;
      line-height: 1.12;
      color: #0f3816;
      font-size: clamp(2rem, 4.6vw, 3.8rem);
      margin-bottom: 1rem;
    }

    .hero p {
      color: #48644e;
      font-size: 1.08rem;
      max-width: 600px;
    }

    .hero-copy {
      animation: fadeSlideUp 0.9s ease both;
    }

    .hero-actions .btn-main {
      min-width: 175px;
    }

    .hero-visual-wrap {
      position: relative;
      min-height: 420px;
      animation: fadeSlideUp 1.1s ease both;
    }

    .glass-panel {
      background: rgba(255, 255, 255, 0.54);
      border: 1px solid rgba(255, 255, 255, 0.65);
      backdrop-filter: blur(12px);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-soft);
      padding: 1.4rem;
      position: relative;
      z-index: 3;
    }

    .mock-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .mock-dots span {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 5px;
      background: #bddfbe;
    }

    .mock-dots span:nth-child(2) {
      background: #8ccc90;
    }

    .mock-dots span:nth-child(3) {
      background: #2E7D32;
    }

    .stat-strip {
      background: rgba(46, 125, 50, 0.12);
      border-radius: 12px;
      padding: 0.72rem;
      font-size: 0.9rem;
      margin-bottom: 0.75rem;
      color: #205628;
      border: 1px solid rgba(46, 125, 50, 0.15);
    }

    .task-row {
      padding: 0.72rem;
      border: 1px solid rgba(46, 125, 50, 0.13);
      border-radius: 12px;
      margin-bottom: 0.68rem;
      background: rgba(255, 255, 255, 0.75);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.9rem;
    }

    .task-row .badge {
      background: rgba(27, 94, 32, 0.14);
      color: #16511c;
      font-weight: 600;
      border-radius: 999px;
      padding: 0.44rem 0.65rem;
    }

    .floating-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(2px);
      opacity: 0.9;
      z-index: 1;
      animation: floatBlob 6.8s ease-in-out infinite;
    }

    .blob-a {
      width: 180px;
      height: 180px;
      top: -32px;
      right: -36px;
      background: radial-gradient(circle at 35% 30%, #d0efcf, #2E7D32);
    }

    .blob-b {
      width: 135px;
      height: 135px;
      bottom: -20px;
      left: -34px;
      animation-delay: 1.1s;
      background: radial-gradient(circle at 35% 30%, #e7f8e6, #5bb060);
    }

    .blob-c {
      width: 90px;
      height: 90px;
      top: 52%;
      right: -20px;
      animation-delay: 0.7s;
      background: radial-gradient(circle at 35% 30%, #ffffff, #90cf94);
    }

    .feature-card,
    .role-card {
      height: 100%;
      border-radius: var(--radius-md);
      border: 1px solid transparent;
      background:
        linear-gradient(#ffffff, #ffffff) padding-box,
        linear-gradient(135deg, rgba(27, 94, 32, 0.68), rgba(165, 214, 167, 0.48)) border-box;
      box-shadow: var(--shadow-card);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .feature-card:hover,
    .role-card:hover {
      transform: translateY(-7px);
      box-shadow: 0 18px 38px rgba(27, 94, 32, 0.18);
    }

    .feature-icon,
    .timeline-icon,
    .role-icon {
      width: 54px;
      height: 54px;
      border-radius: 14px;
      display: inline-flex;
      justify-content: center;
      align-items: center;
      background: linear-gradient(140deg, #E1F3E2, #A5D6A7);
      color: #1B5E20;
      font-size: 1.4rem;
      margin-bottom: 0.8rem;
      animation: pulseIcon 3s ease-in-out infinite;
    }

    .timeline-section {
      background: var(--section-gray);
    }

    .timeline-wrap {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.2rem;
      position: relative;
      margin-top: 2rem;
    }

    .timeline-wrap::before {
      content: "";
      position: absolute;
      top: 26px;
      left: 10%;
      width: 80%;
      height: 2px;
      background: linear-gradient(to right, #7eb783, #2E7D32, #7eb783);
      z-index: 0;
    }

    .timeline-step {
      background: rgba(255, 255, 255, 0.75);
      border: 1px solid rgba(46, 125, 50, 0.16);
      border-radius: 18px;
      padding: 1.2rem;
      position: relative;
      z-index: 1;
      box-shadow: 0 10px 26px rgba(27, 94, 32, 0.08);
    }

    .timeline-step h5 {
      color: #14511b;
      font-weight: 700;
    }

    .role-card {
      background-color: #fff;
    }

    .role-card .btn-main {
      width: 100%;
    }

    .stats-section {
      background: linear-gradient(140deg, #174b1d 0%, #1B5E20 48%, #2E7D32 100%);
      color: #fff;
    }

    .stat-box {
      text-align: center;
      padding: 1rem;
    }

    .stat-number {
      font-size: clamp(2rem, 4vw, 3.1rem);
      font-weight: 800;
      line-height: 1;
      margin-bottom: 0.45rem;
      color: #e4f8e6;
    }

    .cta-section {
      background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 55%, #3f9944 100%);
      color: #fff;
      border-radius: 24px;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow-soft);
    }

    .pulse-btn {
      animation: pulseBtn 2.4s ease-in-out infinite;
    }

    footer {
      background: #113c17;
      color: #e7f7e8;
    }

    footer a {
      color: #d1ead3;
      text-decoration: none;
      transition: color 0.25s ease;
    }

    footer a:hover {
      color: #ffffff;
    }

    .social-links a {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.1);
      margin-right: 0.36rem;
    }

    .social-links a:hover {
      background: rgba(255, 255, 255, 0.2);
    }

    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.66s ease, transform 0.66s ease;
      will-change: opacity, transform;
    }

    .reveal.show {
      opacity: 1;
      transform: translateY(0);
    }

    @keyframes fadeSlideUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes floatBlob {
      0%,
      100% {
        transform: translateY(0) translateX(0);
      }
      50% {
        transform: translateY(-14px) translateX(8px);
      }
    }

    @keyframes pulseBtn {
      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.34);
      }
      70% {
        box-shadow: 0 0 0 12px rgba(255, 255, 255, 0);
      }
    }

    @keyframes pulseIcon {
      0%,
      100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.05);
      }
    }

    @media (max-width: 991.98px) {
      .hero {
        padding-top: 110px;
      }

      .timeline-wrap {
        grid-template-columns: 1fr;
      }

      .timeline-wrap::before {
        display: none;
      }
    }

    @media (max-width: 575.98px) {
      .section-space {
        padding: 72px 0;
      }

      .hero-actions .btn-main {
        width: 100%;
      }

      .hero-actions {
        width: 100%;
      }
    }
  </style>
</head>
<body id="home">
  <nav class="navbar navbar-expand-lg fixed-top site-navbar" id="mainNavbar">
    <div class="container">
      <a class="navbar-brand brand-logo" href="#home">InternTrack</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="#features">Features</a></li>
          <li class="nav-item"><a class="nav-link" href="#roles">Roles</a></li>
          <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
          <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
        </ul>
        <div class="d-flex gap-2">
          <a href="/login" class="btn btn-main btn-login">Login</a>
          <a href="#roles" class="btn btn-main btn-outline-main">Get Started</a>
        </div>
      </div>
    </div>
  </nav>

  <header class="hero">
    <div class="container">
      <div class="row align-items-center g-5">
        <div class="col-lg-6">
          <div class="hero-copy parallax-layer" data-speed="0.15">
            <p class="text-uppercase fw-semibold mb-2 text-success">Internship Management System</p>
            <h1>Streamline Internships. Empower Growth.</h1>
            <p class="mb-4">
              InternTrack simplifies attendance tracking, task management, and performance monitoring for institutions.
            </p>
            <div class="hero-actions d-flex flex-wrap gap-3">
              <a href="/login" class="btn btn-main btn-login">Login</a>
              <a href="#features" class="btn btn-main btn-outline-main">Explore Features</a>
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="hero-visual-wrap parallax-layer" data-speed="0.08">
            <div class="floating-blob blob-a"></div>
            <div class="floating-blob blob-b"></div>
            <div class="floating-blob blob-c"></div>
            <div class="glass-panel">
              <div class="mock-header">
                <strong class="text-success-emphasis">InternTrack Dashboard Preview</strong>
                <div class="mock-dots"><span></span><span></span><span></span></div>
              </div>
              <div class="stat-strip d-flex justify-content-between">
                <span>Today Attendance</span>
                <strong>92%</strong>
              </div>
              <div class="stat-strip d-flex justify-content-between">
                <span>Tasks In Progress</span>
                <strong>18</strong>
              </div>
              <div class="task-row">
                <span>Morning Session - CS Department</span>
                <span class="badge">Live</span>
              </div>
              <div class="task-row">
                <span>Mentor Review Submission</span>
                <span class="badge">Due Today</span>
              </div>
              <div class="task-row">
                <span>Supervisor Evaluation Summary</span>
                <span class="badge">Updated</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <section class="section-space" id="features">
    <div class="container">
      <div class="text-center mb-5 reveal">
        <h2 class="section-title">Powerful Features</h2>
        <p class="section-subtitle">Everything your institution needs to manage internship workflows with speed, structure, and clarity.</p>
      </div>
      <div class="row g-4">
        <div class="col-md-6 col-xl-4 reveal">
          <div class="feature-card p-4">
            <div class="feature-icon"><i class="bi bi-people-fill"></i></div>
            <h5>Student Management</h5>
            <p class="mb-0 text-secondary">Maintain complete student records, onboarding status, and internship details in one place.</p>
          </div>
        </div>
        <div class="col-md-6 col-xl-4 reveal">
          <div class="feature-card p-4">
            <div class="feature-icon"><i class="bi bi-calendar-check"></i></div>
            <h5>Attendance Tracking</h5>
            <p class="mb-0 text-secondary">Capture morning and afternoon session attendance with accurate timestamps and status logs.</p>
          </div>
        </div>
        <div class="col-md-6 col-xl-4 reveal">
          <div class="feature-card p-4">
            <div class="feature-icon"><i class="bi bi-list-task"></i></div>
            <h5>Task Assignment and Monitoring</h5>
            <p class="mb-0 text-secondary">Assign tasks by mentor, track completion, and keep every intern aligned with expectations.</p>
          </div>
        </div>
        <div class="col-md-6 col-xl-4 reveal">
          <div class="feature-card p-4">
            <div class="feature-icon"><i class="bi bi-clipboard2-data"></i></div>
            <h5>Performance Evaluation</h5>
            <p class="mb-0 text-secondary">Evaluate intern progress with structured rubrics, mentor notes, and supervisor scoring.</p>
          </div>
        </div>
        <div class="col-md-6 col-xl-4 reveal">
          <div class="feature-card p-4">
            <div class="feature-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <h5>Real-time Progress Tracking</h5>
            <p class="mb-0 text-secondary">Visual dashboards provide immediate insight into attendance, tasks, and overall outcomes.</p>
          </div>
        </div>
        <div class="col-md-6 col-xl-4 reveal">
          <div class="feature-card p-4">
            <div class="feature-icon"><i class="bi bi-diagram-3-fill"></i></div>
            <h5>Multi-role Access System</h5>
            <p class="mb-0 text-secondary">Secure and role-based access for students, mentors, and supervisors with tailored tools.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space timeline-section" id="about">
    <div class="container">
      <div class="text-center mb-4 reveal">
        <h2 class="section-title">How InternTrack Works</h2>
        <p class="section-subtitle">A structured workflow that keeps everyone aligned from onboarding to final performance review.</p>
      </div>
      <div class="timeline-wrap">
        <article class="timeline-step reveal">
          <div class="timeline-icon"><i class="bi bi-person-plus-fill"></i></div>
          <h5>Step 1</h5>
          <p class="mb-0 text-secondary">Students register, complete profiles, and join their internship placements.</p>
        </article>
        <article class="timeline-step reveal">
          <div class="timeline-icon"><i class="bi bi-person-workspace"></i></div>
          <h5>Step 2</h5>
          <p class="mb-0 text-secondary">Mentors manage attendance and assign tasks with clear daily accountability.</p>
        </article>
        <article class="timeline-step reveal">
          <div class="timeline-icon"><i class="bi bi-shield-check"></i></div>
          <h5>Step 3</h5>
          <p class="mb-0 text-secondary">Supervisors monitor analytics, evaluate outcomes, and ensure quality standards.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section-space" id="roles">
    <div class="container">
      <div class="text-center mb-5 reveal">
        <h2 class="section-title">User Roles</h2>
        <p class="section-subtitle">Dedicated experiences designed around each role in the internship ecosystem.</p>
      </div>
      <div class="row g-4 justify-content-center">
        <div class="col-md-6 col-lg-4 reveal">
          <div class="role-card p-4 text-center">
            <div class="role-icon mx-auto"><i class="bi bi-mortarboard-fill"></i></div>
            <h5>Student</h5>
            <p class="text-secondary">Track attendance, complete assigned tasks, and stay updated with mentor feedback.</p>
            <a href="/student/login" class="btn btn-main btn-login mt-2">Student Login</a>
          </div>
        </div>
        <div class="col-md-6 col-lg-4 reveal">
          <div class="role-card p-4 text-center">
            <div class="role-icon mx-auto"><i class="bi bi-briefcase-fill"></i></div>
            <h5>Mentor</h5>
            <p class="text-secondary">Mark attendance, guide intern tasks, and submit structured evaluations.</p>
            <a href="/mentor/login" class="btn btn-main btn-login mt-2">Mentor Login</a>
          </div>
        </div>
        <div class="col-md-6 col-lg-4 reveal">
          <div class="role-card p-4 text-center">
            <div class="role-icon mx-auto"><i class="bi bi-building-check"></i></div>
            <h5>Supervisor</h5>
            <p class="text-secondary">Review progress data, verify standards, and monitor internship performance.</p>
            <a href="/supervisor/login" class="btn btn-main btn-login mt-2">Supervisor Login</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space stats-section">
    <div class="container">
      <div class="row g-4 text-center">
        <div class="col-6 col-lg-3 reveal">
          <div class="stat-box">
            <div class="stat-number" data-target="100">0</div>
            <p class="mb-0">Interns Managed</p>
          </div>
        </div>
        <div class="col-6 col-lg-3 reveal">
          <div class="stat-box">
            <div class="stat-number" data-target="50">0</div>
            <p class="mb-0">Mentors</p>
          </div>
        </div>
        <div class="col-6 col-lg-3 reveal">
          <div class="stat-box">
            <div class="stat-number" data-target="30">0</div>
            <p class="mb-0">Supervisors</p>
          </div>
        </div>
        <div class="col-6 col-lg-3 reveal">
          <div class="stat-box">
            <div class="stat-number" data-target="95">0</div>
            <p class="mb-0">Attendance Accuracy</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container my-5" id="contact">
    <div class="cta-section text-center p-4 p-md-5 reveal">
      <h2 class="fw-bold mb-3">Ready to Transform Internship Management?</h2>
      <p class="mb-4">Join institutions using InternTrack to simplify collaboration between students, mentors, and supervisors.</p>
      <a href="/login" class="btn btn-light btn-main pulse-btn px-4">Login to InternTrack</a>
    </div>
  </section>

  <footer class="pt-5 pb-3">
    <div class="container">
      <div class="row g-4">
        <div class="col-lg-4">
          <h4 class="fw-bold mb-3">InternTrack</h4>
          <p class="mb-3">Professional internship management platform connecting students, mentors, and supervisors.</p>
          <div class="social-links">
            <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
            <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
            <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
            <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
          </div>
