<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>My Profile | InternTrack</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

  <!-- Main CSS -->
  <link rel="stylesheet" href="/stylesheets/student.css">
  <link rel="stylesheet" href="/stylesheets/style.css">

  <style>
    :root {
      --accent: #4CAF50;
      --accent-soft: rgba(76, 175, 80, 0.12);
      --text-dark: #1f2a1f;
      --text-muted: #6b7b6b;
      --card-bg: #ffffff;
      --page-bg: #f5fbf5;
      --divider: #e2eee2;
      --shadow: 0 10px 24px rgba(32, 60, 32, 0.08);
    }

    body {
      background: var(--page-bg);
      color: var(--text-dark);
    }

    .profile-page {
      padding-bottom: 48px;
    }

    .profile-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 20px;
      margin: 28px 0 20px;
      animation: fadeUp 0.6s ease;
    }

    .profile-header h1 {
      font-size: 28px;
      margin-bottom: 6px;
    }

    .profile-header p {
      color: var(--text-muted);
      margin: 0;
    }

    .section-card {
      background: var(--card-bg);
      border: 1px solid var(--divider);
      border-radius: 16px;
      padding: 22px;
      box-shadow: var(--shadow);
      margin-bottom: 18px;
      animation: fadeUp 0.6s ease;
    }

    .profile-overview {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      flex-wrap: wrap;
    }

    .profile-overview-left {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .avatar-wrap {
      position: relative;
      width: 92px;
      height: 92px;
      border-radius: 50%;
      overflow: hidden;
      border: 4px solid var(--accent-soft);
      background: #ffffff;
    }

    .avatar-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .avatar-upload {
      position: absolute;
      right: -2px;
      bottom: -2px;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 2px solid #ffffff;
      background: var(--accent);
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      cursor: pointer;
      box-shadow: 0 6px 12px rgba(76, 175, 80, 0.3);
    }

    .profile-meta h2 {
      margin: 0 0 6px;
      font-size: 22px;
    }

    .profile-meta p {
      margin: 0;
      color: var(--text-muted);
      font-size: 14px;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
      text-transform: capitalize;
      background: rgba(76, 175, 80, 0.15);
      color: var(--accent);
    }

    .status-completed {
      background: rgba(72, 146, 255, 0.15);
      color: #2d5fd8;
    }

    .progress-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
    }

    .progress-info h3 {
      margin: 0 0 6px;
      font-size: 18px;
    }

    .progress-info p {
      margin: 0;
      color: var(--text-muted);
    }

    .progress-bar {
      width: 100%;
      height: 10px;
      border-radius: 999px;
      background: #e5f2e5;
      overflow: hidden;
      margin-top: 10px;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #4CAF50, #7bdc84);
      width: 0;
      transition: width 0.4s ease;
    }

    .details-section {
      border-top: 1px solid var(--divider);
      padding-top: 10px;
      margin-top: 12px;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 12px;
    }

    .section-header h3 {
      margin: 0;
      font-size: 18px;
    }

    .section-note {
      font-size: 13px;
      color: var(--text-muted);
    }

    .details-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .info-item {
      border: 1px solid var(--divider);
      border-radius: 12px;
      padding: 14px 14px 12px;
      background: #fbfefb;
      position: relative;
      transition: border 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .info-item:hover {
      border-color: rgba(76, 175, 80, 0.4);
      box-shadow: 0 8px 16px rgba(76, 175, 80, 0.08);
      background: #ffffff;
    }

    .info-item.readonly {
      background: #f7fbf7;
      border-style: dashed;
    }

    .info-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-muted);
      margin-bottom: 6px;
    }

    .info-value {
      font-size: 15px;
      font-weight: 500;
      min-height: 20px;
      outline: none;
      color: var(--text-dark);
    }

    .info-value.is-empty::before {
      content: attr(data-placeholder);
      color: #9bb59e;
      font-weight: 400;
    }

    .info-item.editing {
      border-color: rgba(76, 175, 80, 0.6);
      background: #ffffff;
    }

    .edit-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      border: none;
      background: var(--accent-soft);
      color: var(--accent);
      border-radius: 8px;
      font-size: 12px;
      padding: 4px 8px;
      cursor: pointer;
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .edit-btn:hover {
      background: rgba(76, 175, 80, 0.2);
      transform: translateY(-1px);
    }

    .field-message {
      margin-top: 6px;
      font-size: 12px;
      color: #e07b2f;
      display: none;
    }

    .field-message.show {
      display: block;
    }

    .actions-row {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      animation: fadeUp 0.6s ease;
    }

    .save-message {
      margin-left: auto;
      font-size: 14px;
      color: var(--accent);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .save-message.show {
      opacity: 1;
    }

    .btn.btn-secondary {
      background: #eaf6ea;
      color: var(--accent);
      border: 1px solid rgba(76, 175, 80, 0.2);
    }

    .btn[disabled] {
      opacity: 0.6;
      cursor: not-allowed;
    }

    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(16px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 900px) {
      .details-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .profile-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .profile-overview {
        flex-direction: column;
        align-items: flex-start;
      }

      .profile-overview-left {
        width: 100%;
      }

      .actions-row {
        width: 100%;
      }

      .save-message {
        width: 100%;
        margin-left: 0;
      }
    }
  </style>
</head>
<body>

<!-- ================= STUDENT NAVBAR ================= -->
<%- include('../partials/navbar.ejs') %>

<%
  const studentData = student || {};
  const fullName = studentData.fullName || (studentData.firstName ? `${studentData.firstName} ${studentData.lastName || ''}`.trim() : 'Aarav Mehta');
  const studentId = studentData.registerNumber || studentData.studentId || 'ITK-2026-014';
  const profileImage = studentData.profileImage && studentData.profileImage.trim() !== '' ? studentData.profileImage : '/images/default.png';
  const internshipTitle = studentData.internshipTitle || studentData.companyName || 'Frontend Intern';
  const statusLabel = studentData.status || 'Active';
%>

<main class="content-main profile-page">

  <section class="profile-header">
    <div>
      <h1>My Profile</h1>
      <p>Complete and keep your profile up to date for better internship tracking</p>
    </div>
  </section>

  <section class="section-card profile-overview">
    <div class="profile-overview-left">
      <div class="avatar-wrap">
        <img id="profileAvatar" src="<%= profileImage %>" alt="<%= fullName %>">
        <label class="avatar-upload" for="avatarInput" title="Change photo">Edit</label>
        <input id="avatarInput" type="file" accept="image/*" hidden>
      </div>
      <div class="profile-meta">
        <h2><%= fullName %></h2>
        <p>Register No: <strong><%= studentId %></strong></p>
        <p><%= internshipTitle %></p>
      </div>
    </div>
    <span class="status-badge <%= statusLabel.toLowerCase() === 'completed' ? 'status-completed' : '' %>"><%= statusLabel %></span>
  </section>

  <section class="section-card progress-card" id="profileCompletion">
    <div class="progress-info">
      <h3>Profile Completion: <span id="completionValue">70%</span></h3>
      <p>Finish a few more details to make your profile stand out.</p>
      <div class="progress-bar">
        <div class="progress-fill" id="completionBar"></div>
      </div>
    </div>
  </section>

  <section class="section-card">
    <div class="section-header">
      <h3>Profile Details</h3>
      <span class="section-note">Click any field to edit</span>
    </div>
    <div class="details-grid">
      <div class="info-item editable" data-field="fullName" data-required="true" data-track="true">
        <div class="info-label">Full Name</div>
        <div class="info-value" data-placeholder="Add full name"><%= fullName %></div>
        <button class="edit-btn" type="button">Edit</button>
        <div class="field-message">This field is required.</div>
      </div>
      <div class="info-item readonly" data-field="email" data-track="true">
        <div class="info-label">Email Address</div>
        <div class="info-value"><%= studentData.email || studentData.studentEmail || 'aarav.mehta@college.edu' %></div>
      </div>
      <div class="info-item editable" data-field="phone" data-required="true" data-track="true">
        <div class="info-label">Phone Number</div>
        <div class="info-value" data-placeholder="Add phone number"><%= studentData.phone || '+91 9XXXXXX123' %></div>
        <button class="edit-btn" type="button">Edit</button>
        <div class="field-message">This field is required.</div>
      </div>
      <div class="info-item editable" data-field="registerNumber" data-required="true" data-track="true">
        <div class="info-label">Register Number</div>
        <div class="info-value" data-placeholder="Add register number"><%= studentId %></div>
        <button class="edit-btn" type="button">Edit</button>
        <div class="field-message">This field is required.</div>
      </div>
      <div class="info-item editable" data-field="department" data-required="true" data-track="true">
        <div class="info-label">Department</div>
        <div class="info-value" data-placeholder="Add department"><%= studentData.department || 'Computer Science' %></div>
        <button class="edit-btn" type="button">Edit</button>
        <div class="field-message">This field is required.</div>
      </div>
      <div class="info-item editable" data-field="yearSemester" data-required="true" data-track="true">
        <div class="info-label">Year / Semester</div>
        <div class="info-value" data-placeholder="Add year & semester"><%= studentData.yearSemester || '3rd Year / Sem 6' %></div>
        <button class="edit-btn" type="button">Edit</button>
        <div class="field-message">This field is required.</div>
      </div>
      <div class="info-item editable" data-field="collegeName" data-required="true" data-track="true">
        <div class="info-label">College / Institution</div>
        <div class="info-value" data-placeholder="Add institution name"><%= studentData.collegeName || 'Greenfield Institute of Technology' %></div>
        <button class="edit-btn" type="button">Edit</button>
        <div class="field-message">This field is required.</div>
      </div>
      <div class="info-item editable" data-field="internshipTitle" data-track="true">
        <div class="info-label">Internship Title</div>
        <div class="info-value" data-placeholder="Add internship title"><%= internshipTitle %></div>
        <button class="edit-btn" type="button">Edit</button>
        <div class="field-message">Please add the title.</div>
      </div>
    </div>

    <div class="details-section">
      <div class="section-header">
        <h3>Additional Details</h3>
        <span class="section-note">Add a little more about you</span>
      </div>
      <div class="details-grid">
        <div class="info-item editable" data-field="dob" data-track="true">
          <div class="info-label">Date of Birth</div>
          <div class="info-value" data-placeholder="Add date of birth"><%= studentData.dob || '' %></div>
          <button class="edit-btn" type="button">Edit</button>
          <div class="field-message">Please add a valid date.</div>
        </div>
        <div class="info-item editable" data-field="gender" data-track="true">
          <div class="info-label">Gender (Optional)</div>
          <div class="info-value" data-placeholder="Add gender"><%= studentData.gender || '' %></div>
          <button class="edit-btn" type="button">Edit</button>
          <div class="field-message">Optional.</div>
        </div>
        <div class="info-item editable" data-field="address" data-track="true">
          <div class="info-label">Address</div>
          <div class="info-value" data-placeholder="Add address"><%= studentData.address || '' %></div>
          <button class="edit-btn" type="button">Edit</button>
          <div class="field-message">Please add your address.</div>
        </div>
        <div class="info-item editable" data-field="skills" data-track="true">
          <div class="info-label">Skills / Technologies</div>
          <div class="info-value" data-placeholder="Add skills"><%= studentData.skills || '' %></div>
          <button class="edit-btn" type="button">Edit</button>
          <div class="field-message">Add at least one skill.</div>
        </div>
        <div class="info-item editable" data-field="linkedin" data-type="link" data-track="true">
          <div class="info-label">LinkedIn Profile</div>
          <div class="info-value" data-placeholder="Add LinkedIn link"><%= studentData.linkedin || '' %></div>
          <button class="edit-btn" type="button">Edit</button>
          <div class="field-message">Add full link starting with http.</div>
        </div>
        <div class="info-item editable" data-field="github" data-type="link" data-track="true">
          <div class="info-label">GitHub Profile</div>
          <div class="info-value" data-placeholder="Add GitHub link"><%= studentData.github || '' %></div>
          <button class="edit-btn" type="button">Edit</button>
          <div class="field-message">Add full link starting with http.</div>
        </div>
        <div class="info-item editable" data-field="bio" data-track="true">
          <div class="info-label">Short Bio / Objective</div>
          <div class="info-value" data-placeholder="Add a short bio"><%= studentData.bio || '' %></div>
          <button class="edit-btn" type="button">Edit</button>
          <div class="field-message">Share a short objective.</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-card actions-row">
    <button class="btn btn-primary" id="saveProfile" type="button" disabled>Save Profile</button>
    <button class="btn btn-secondary" id="cancelProfile" type="button" disabled>Cancel Changes</button>
    <span class="save-message" id="saveMessage">Profile updated successfully.</span>
  </section>

</main>

<script>
  const editableItems = document.querySelectorAll('.info-item.editable');
  const saveButton = document.getElementById('saveProfile');
  const cancelButton = document.getElementById('cancelProfile');
  const saveMessage = document.getElementById('saveMessage');
  const completionValue = document.getElementById('completionValue');
  const completionBar = document.getElementById('completionBar');
  const avatarInput = document.getElementById('avatarInput');
  const profileAvatar = document.getElementById('profileAvatar');

  const initialValues = new Map();

  const updateEmptyState = (valueEl) => {
    const isEmpty = valueEl.textContent.trim() === '';
    valueEl.classList.toggle('is-empty', isEmpty);
  };

  const showValidation = (item, message) => {
    const fieldMessage = item.querySelector('.field-message');
    if (!fieldMessage) return;
    if (message) {
      fieldMessage.textContent = message;
      fieldMessage.classList.add('show');
    } else {
      fieldMessage.classList.remove('show');
    }
  };

  const validateItem = (item) => {
    const valueEl = item.querySelector('.info-value');
    const value = valueEl.textContent.trim();
    const isRequired = item.dataset.required === 'true';
    const isLink = item.dataset.type === 'link';

    if (isRequired && value === '') {
      showValidation(item, 'This field is required.');
      return false;
    }

    if (isLink && value !== '' && !/^https?:\/\//i.test(value)) {
      showValidation(item, 'Add full link starting with http.');
      return false;
    }

    showValidation(item, '');
    return true;
  };

  const updateDirtyState = () => {
    let dirty = false;
    editableItems.forEach((item) => {
      const valueEl = item.querySelector('.info-value');
      const key = item.dataset.field;
      const initial = initialValues.get(key) || '';
      if (valueEl.textContent.trim() !== initial) {
        dirty = true;
      }
    });
    saveButton.disabled = !dirty;
    cancelButton.disabled = !dirty;
  };

  const updateCompletion = () => {
    const trackItems = document.querySelectorAll('.info-item[data-track="true"] .info-value');
    let filled = 0;
    trackItems.forEach((valueEl) => {
      if (valueEl.textContent.trim() !== '') filled += 1;
    });
    const percent = Math.round((filled / trackItems.length) * 100);
    completionValue.textContent = `${percent}%`;
    completionBar.style.width = `${percent}%`;
  };

  editableItems.forEach((item) => {
    const valueEl = item.querySelector('.info-value');
    const editButton = item.querySelector('.edit-btn');
    const key = item.dataset.field;

    initialValues.set(key, valueEl.textContent.trim());
    valueEl.setAttribute('contenteditable', 'false');
    updateEmptyState(valueEl);

    const startEditing = () => {
      valueEl.setAttribute('contenteditable', 'true');
      valueEl.focus();
      item.classList.add('editing');
    };

    editButton.addEventListener('click', (event) => {
      event.stopPropagation();
      startEditing();
    });

    item.addEventListener('click', () => {
      if (!item.classList.contains('editing')) startEditing();
    });

    valueEl.addEventListener('input', () => {
      updateEmptyState(valueEl);
      updateDirtyState();
      validateItem(item);
      updateCompletion();
    });

    valueEl.addEventListener('blur', () => {
      valueEl.setAttribute('contenteditable', 'false');
      item.classList.remove('editing');
      updateDirtyState();
      validateItem(item);
      updateCompletion();
    });

    valueEl.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        valueEl.blur();
      }
    });
  });

  if (avatarInput) {
    avatarInput.addEventListener('change', (event) => {
      const [file] = event.target.files || [];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        profileAvatar.src = e.target.result;
        saveMessage.classList.remove('show');
      };
      reader.readAsDataURL(file);
      saveButton.disabled = false;
      cancelButton.disabled = false;
    });
  }

  saveButton.addEventListener('click', () => {
    editableItems.forEach((item) => {
      const valueEl = item.querySelector('.info-value');
      initialValues.set(item.dataset.field, valueEl.textContent.trim());
    });
    saveButton.disabled = true;
    cancelButton.disabled = true;
    saveMessage.classList.add('show');
    setTimeout(() => saveMessage.classList.remove('show'), 2000);
  });

  cancelButton.addEventListener('click', () => {
    editableItems.forEach((item) => {
      const valueEl = item.querySelector('.info-value');
      valueEl.textContent = initialValues.get(item.dataset.field) || '';
      updateEmptyState(valueEl);
      validateItem(item);
    });
    saveButton.disabled = true;
    cancelButton.disabled = true;
    saveMessage.classList.remove('show');
    updateCompletion();
  });

  updateCompletion();
  updateDirtyState();
</script>
</body>
</html>
